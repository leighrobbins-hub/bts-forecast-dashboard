# Looker API credentials
# Copy this file to .env and fill in your values.
# See SETUP.md for how to create API keys and find Look IDs.

LOOKER_CLIENT_ID=your_client_id_here
LOOKER_CLIENT_SECRET=your_client_secret_here
LOOKER_API_URL=https://varsitytutors.looker.com

# Look IDs (preferred — stable, won't change when the Look is edited)
# Find these in the URL: https://varsitytutors.looker.com/looks/12345 → ID is 12345
LOOKER_RUN_RATE_LOOK_ID=
LOOKER_UTILIZATION_LOOK_ID=
LOOKER_ACTUALS_LOOK_ID=
LOOKER_NAT_P90_LOOK_ID=26319

# Query IDs (alternative — use if you don't have saved Looks)
# Find in Explore URL: ?qid=AbCdEfGhIjK → ID is AbCdEfGhIjK
# LOOKER_RUN_RATE_QUERY_ID=
# LOOKER_UTILIZATION_QUERY_ID=
